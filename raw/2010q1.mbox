>
>    result = dbGetQuery(databaseConnection, query)
>
>    strftime(result$timestamptz, usetz=TRUE)  # prints:"1999-12-31 01:00:00 UTC"
[1] "1999-12-30 19:00:00 EST"

>    as.numeric(result$timestamptz)
[1] 946598400
> format(result, tz = "GMT")
