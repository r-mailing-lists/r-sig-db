     dat <- sqlQuery(con, paste( "SELECT", paste(keep.cols, collapse=","),
"FROM", tables[i], sep=" ") )
  }else{
    dat <- try( sqlFetch(con, tables[i]), silent=F)
  }
  print(i)
  print( paste(tables[i]) )
  print( object.size(dat),  units = "auto" )
  saveRDS(dat, paste(tables[i], "rds", sep=".") ) }
##################################

##################################

Cheers!
Patrick


