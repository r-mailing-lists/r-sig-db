>                m <- if (no.data.base.drivers.loaded)
>                        dbDriver("SQLite")
>                else loaded.driver
>        }
>        if (missing(con)) {
>                con <- if (no.connections.open)
>                        dbConnect(m, dbname)
>                active.connection
>        }
>        dbWriteTable(con, "iris", iris)
>        dbGetQuery(con, "select * from iris limit 3")
> }

dbListConnections(SQLite()) will tell you about open connections to
the SQLite driver.

