drv <- dbDriver("MySQL")
con <- dbConnect(drv, ...)

rs1 <- dbSendQuery(con, "SELECT ...")

while (!dbHasCompleted(rs1)) {
  data1 <- fetch(rs1, n=1)

  rs2 <- dbSendQuery(con, past("SELECT ... WHERE id =", data1$id))
  data2 <- fetch(rs2, n=1)

  dbClearResult(rs2)
